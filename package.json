{
  "name": "multitool-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server \"npm:dev:client\" \"npm:server\"",
    "dev:client": "vite --host 127.0.0.1",
    "server": "node server/index.mjs",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.mjs"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "0.12.15",
    "@ffmpeg/util": "0.12.2",
    "@google/genai": "^2.9.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/rus": "^1.0.0",
    "adm-zip": "^0.5.17",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "0.468.0",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pdf-lib": "1.17.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/qrcode": "1.5.5",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "vite": "6.4.3"
  }
}
